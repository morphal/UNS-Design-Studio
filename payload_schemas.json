{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "All accepted UNS data contracts",
  "anyOf": [
    {
      "title": "Contract 1001 - Standard value with epoch timestamp, unit and quality",
      "type": "object",
      "properties": {
        "datacontract_id": {
          "const": 1001
        },
        "value": {
          "type": "number"
        },
        "ts": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "quality": {
          "type": "string"
        }
      },
      "required": [
        "datacontract_id",
        "value",
        "ts",
        "unit",
        "quality"
      ]
    },
    {
      "title": "Contract 1002 - Simple value with epoch timestamp",
      "type": "object",
      "properties": {
        "datacontract_id": {
          "const": 1002
        },
        "value": {
          "type": "number"
        },
        "ts": {
          "type": "number"
        }
      },
      "required": [
        "datacontract_id",
        "value",
        "ts"
      ]
    },
    {
      "title": "Contract 1003 - Sparkplug B-like payload",
      "type": "object",
      "properties": {
        "datacontract_id": {
          "const": 1003
        },
        "name": {
          "type": "string"
        },
        "value": {
          "type": "number"
        },
        "timestamp": {
          "type": "integer"
        },
        "dataType": {
          "type": "string"
        },
        "quality": {
          "type": "string"
        }
      },
      "required": [
        "datacontract_id",
        "name",
        "value",
        "timestamp",
        "dataType",
        "quality"
      ]
    },
    {
      "title": "Contract 1004 - ISA-95 Extended payload",
      "type": "object",
      "properties": {
        "datacontract_id": {
          "const": 1004
        },
        "v": {
          "type": "number"
        },
        "q": {
          "type": "string"
        },
        "t": {
          "type": "string"
        },
        "uom": {
          "type": "string"
        },
        "tagPath": {
          "type": "string"
        },
        "dataType": {
          "type": "string"
        },
        "site": {
          "type": "string"
        }
      },
      "required": [
        "datacontract_id",
        "v",
        "q",
        "t",
        "uom",
        "tagPath",
        "dataType",
        "site"
      ]
    }
  ]
}